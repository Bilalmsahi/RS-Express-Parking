# Copy to .env and fill in real values. Never commit the real .env.

# Django
DJANGO_SECRET_KEY="generate-a-50+-char-random-string"
DEBUG=True

# Database (MySQL)
DB_NAME="rsexpressparking"
DB_USER="root"
DB_PASSWORD="your-db-password"
DB_HOST="localhost"
DB_PORT=3306

# Stripe (use test keys in dev: sk_test_/pk_test_)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (Hostinger SMTP)
EMAIL_HOST="smtp.hostinger.com"
EMAIL_PORT=587
EMAIL_HOST_USER="support@example.com"
EMAIL_HOST_PASSWORD="your-smtp-password"
DUBLIN_EMAIL_HOST_PASSWORD="your-dublin-smtp-password"
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL="support@example.com"

# Optional
REDIS_CACHE_URL=""
PASSWORD_RESET_TIMEOUT=3600
FRONTEND_RS_RESET_PASSWORD_URL="https://www.rsexpressparking.com/reset-password"
FRONTEND_DUBLIN_RESET_PASSWORD_URL="https://www.dublinairportexpressparking.ie/reset-password"
